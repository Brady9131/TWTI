const SITE_TAGLINE = "测测你的台女音乐人格是谁";

const ARTIST_ORDER = [
  "anpu",
  "cheer",
  "lala",
  "waa",
  "rainie",
  "ennong",
  "jolin",
  "eve",
  "sandee",
  "shiqi",
  "alin",
  "tanya",
  "hebe",
];

/**
 * 音乐人六维画像（文艺、甜感、酷飒、疗愈、实验、态度）：态度=对行业底线/争议的立场鲜明度（非温柔度）
 * - 每题选项 dims 合计 10；经 dimMul 后再缩放到合计 10 分记入 dimTotals → 24 题后六维合计恒为 240
 * - 歌手 ARTIST_PROFILE_RAW 为设计稿，运行时缩放到六维合计 240，与用户同一绝对分尺度匹配与展示
 * - 本命相似度：① 各维减均匀分 240/6 中心化；② 按 13 人画像每维 σ 缩放；③ 占比过低维对歌手「偏高」惩罚；④ 近分用答题路径哈希并列择一
 * - 专辑 dims 按比例缩放到 240 再与用户比
 */
/** 全卷六维总分（与用户、歌手画像一致） */
const PROFILE_TOTAL = 240;
/** 六维均匀分布时每维分数（中性基准） */
const PROFILE_CENTER_ABS = PROFILE_TOTAL / 6;
/** 与第一名分差 ≤ 此值的歌手视为「并列候选」，由答题路径决定最终本命（扩大覆盖面、减少总落在郑宜农/艾怡良等高分区歌手上） */
const NEAR_TOP_SCORE_DELTA = 0.05;
/** 歌手池内标准差下限，避免除零或单维爆炸 */
const ZSCORE_STD_FLOOR = 4;
/** 用户某维低于总分该比例时，对歌手该维「偏高」施加惩罚 */
const LOW_DIM_SHARE = 0.1;
const MISMATCH_PENALTY_K = 0.11;

const ARTIST_PROFILE_RAW = {
  anpu: [94, 20, 22, 46, 40, 88],
  cheer: [84, 46, 18, 42, 38, 52],
  lala: [36, 92, 24, 80, 22, 42],
  waa: [42, 44, 28, 50, 90, 55],
  rainie: [22, 94, 34, 56, 18, 38],
  ennong: [80, 20, 36, 54, 62, 84],
  jolin: [32, 38, 96, 44, 74, 78],
  eve: [54, 30, 30, 92, 46, 48],
  sandee: [74, 14, 28, 36, 94, 92],
  shiqi: [44, 46, 38, 46, 88, 46],
  alin: [28, 60, 88, 64, 22, 58],
  tanya: [86, 34, 26, 56, 42, 54],
  hebe: [90, 28, 22, 66, 48, 42],
};

/** 将非负六维按比例缩放到整数且合计为 targetTotal（最大余数法） */
function scaleVectorToTotal(raw, targetTotal) {
  const nums = raw.map((v) => Number(v));
  const sum = nums.reduce((a, b) => a + b, 0);
  if (sum <= 0) {
    const base = Math.floor(targetTotal / 6);
    let rem = targetTotal - base * 6;
    return Array.from({ length: 6 }, (_, i) => base + (i < rem ? 1 : 0));
  }
  const exact = nums.map((v) => (v / sum) * targetTotal);
  const floors = exact.map((x) => Math.floor(x));
  let rem = targetTotal - floors.reduce((a, b) => a + b, 0);
  const order = exact
    .map((x, i) => ({ i, r: x - Math.floor(x) }))
    .sort((a, b) => b.r - a.r);
  const out = floors.slice();
  for (let k = 0; k < rem; k++) {
    out[order[k].i] += 1;
  }
  return out;
}

const ARTIST_PROFILE = Object.fromEntries(
  ARTIST_ORDER.map((id) => [id, scaleVectorToTotal(ARTIST_PROFILE_RAW[id], PROFILE_TOTAL)])
);

function computeArtistPoolDimStd() {
  const dims = 6;
  const n = ARTIST_ORDER.length;
  const sums = Array(dims).fill(0);
  for (let i = 0; i < n; i++) {
    const p = ARTIST_PROFILE[ARTIST_ORDER[i]];
    for (let d = 0; d < dims; d++) sums[d] += p[d];
  }
  const means = sums.map((s) => s / n);
  const acc = Array(dims).fill(0);
  for (let i = 0; i < n; i++) {
    const p = ARTIST_PROFILE[ARTIST_ORDER[i]];
    for (let d = 0; d < dims; d++) {
      const t = p[d] - means[d];
      acc[d] += t * t;
    }
  }
  return acc.map((s) => Math.max(Math.sqrt(s / n), ZSCORE_STD_FLOOR));
}

const ARTIST_DIM_STD = computeArtistPoolDimStd();

function cosineSimNorm(a, b) {
  const n = Math.min(a.length, b.length);
  let dotp = 0;
  let na = 0;
  let nb = 0;
  for (let i = 0; i < n; i++) {
    dotp += a[i] * b[i];
    na += a[i] * a[i];
    nb += b[i] * b[i];
  }
  const d = Math.sqrt(na) * Math.sqrt(nb);
  return d ? dotp / d : 0;
}

function centerProfileVec(v) {
  return v.map((x) => Number(x) - PROFILE_CENTER_ABS);
}

/** 六维（合计 240）先减均匀基准，再按歌手池每维 σ 缩放，最后余弦 */
function zscoreCenterProfileVec(v) {
  const c = centerProfileVec(v);
  return c.map((x, i) => x / ARTIST_DIM_STD[i]);
}

function profileSimilarityCosine(userVec, artistVec) {
  return cosineSimNorm(zscoreCenterProfileVec(userVec), zscoreCenterProfileVec(artistVec));
}

function userDimShares(userNorm) {
  const nums = userNorm.map((x) => Number(x));
  const sum = nums.reduce((a, b) => a + b, 0) || PROFILE_TOTAL;
  return nums.map((v) => v / sum);
}

/** 用户某维占比过低时，压低该维画像偏高的歌手得分 */
function artistLowDimMismatchPenalty(userNorm, artistId) {
  const shares = userDimShares(userNorm);
  const prof = ARTIST_PROFILE[artistId];
  let penalty = 0;
  for (let d = 0; d < 6; d++) {
    if (shares[d] >= LOW_DIM_SHARE) continue;
    const gap = LOW_DIM_SHARE - shares[d];
    const artistLean =
      Math.max(0, prof[d] - PROFILE_CENTER_ABS) / (PROFILE_TOTAL - PROFILE_CENTER_ABS);
    penalty += MISMATCH_PENALTY_K * artistLean * (gap / LOW_DIM_SHARE);
  }
  return penalty;
}

function profileSimilarityToArtist(userNorm, artistId) {
  const artistVec = ARTIST_PROFILE[artistId];
  return profileSimilarityCosine(userNorm, artistVec) - artistLowDimMismatchPenalty(userNorm, artistId);
}

/** 每题轮换强化一维（六维循环），与选项 dims 相乘 */
function dimMulForQuestionIndex(qi) {
  const slot = qi % 6;
  return [0, 1, 2, 3, 4, 5].map((i) => (i === slot ? 1.55 : 1));
}

/** 用户六维总分 240 与每位歌手画像的余弦相似度（经中心化与池内 σ 缩放），越高越像 */
function getArtistProfileSimilarityScores(userNorm) {
  const scores = {};
  ARTIST_ORDER.forEach((id) => {
    scores[id] = profileSimilarityToArtist(userNorm, id);
  });
  return scores;
}

function rankArtistsByProfileSimilarity(userNorm) {
  return ARTIST_ORDER.map((id) => ({
    id,
    score: profileSimilarityToArtist(userNorm, id),
  })).sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;
    return ARTIST_ORDER.indexOf(a.id) - ARTIST_ORDER.indexOf(b.id);
  });
}

/** 与专辑 tie-break 同思路：同一路径始终得到同一本命，不同路径分散到并列高分歌手 */
function pathHashForArtistPick() {
  let h = hashString(":artistPick");
  (answerHistory || []).forEach((entry, qi) => {
    h = (h * 31 + qi) >>> 0;
    h = (h ^ hashString(entry.opt && entry.opt.text)) >>> 0;
  });
  return h >>> 0;
}

function pickArtistByProfileSimilarity(userNorm) {
  const scores = getArtistProfileSimilarityScores(userNorm);
  const sorted = ARTIST_ORDER.map((id) => ({ id, score: scores[id] })).sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;
    return ARTIST_ORDER.indexOf(a.id) - ARTIST_ORDER.indexOf(b.id);
  });
  const best = sorted[0].score;
  const nearTop = sorted.filter((x) => best - x.score <= NEAR_TOP_SCORE_DELTA);
  if (nearTop.length === 1) return nearTop[0].id;
  const idx = pathHashForArtistPick() % nearTop.length;
  return nearTop[idx].id;
}

