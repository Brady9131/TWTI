function resolveAlbumCoverUrl(album, artist) {
  if (album && album.coverUrl) return album.coverUrl;
  const id = album && album.neteaseId;
  if (id && NETEASE_ALBUM_COVER[String(id)]) return NETEASE_ALBUM_COVER[String(id)];
  return (artist && artist.albumCoverUrl) || "";
}

/** 按用户六维与专辑 dims 选一张专辑（与结果页封面同源逻辑） */
function pickAlbumMetaForNorm(artistId, norm) {
  const artist = ARTISTS[artistId];
  const albums = artist.albums || [];
  if (!albums.length) {
    return {
      title: artist.album,
      neteaseId: "",
      coverUrl: artist.albumCoverUrl || "",
    };
  }
  const neutral = [40, 40, 40, 40, 40, 40];
  const scored = albums.map((al) => {
    const d = al.dims && al.dims.length === 6 ? al.dims : neutral;
    return { al, sim: profileSimilarityCosine(norm, scaleVectorToTotal(d, PROFILE_TOTAL)) };
  });
  scored.sort((a, b) => b.sim - a.sim);
  const bestSim = scored[0].sim;
  const ties = scored.filter((x) => Math.abs(x.sim - bestSim) < 1e-9);
  let h = hashString(artistId);
  (answerHistory || []).forEach((entry, qi) => {
    h = (h * 31 + qi) >>> 0;
    h = (h ^ hashString(entry.opt && entry.opt.text)) >>> 0;
  });
  const picked = ties[h % ties.length].al;
  return {
    title: picked.title,
    neteaseId: picked.neteaseId || "",
    coverUrl: resolveAlbumCoverUrl(picked, artist),
  };
}

function pickAlbumForResult(artistId, norm) {
  return pickAlbumMetaForNorm(artistId, norm);
}

function neteaseSongUrl(id) {
  if (!id) return "";
  return `https://music.163.com/song?id=${id}`;
}
function neteaseAlbumUrl(id) {
  if (!id) return "";
  return `https://music.163.com/album?id=${id}`;
}

function hashString(str) {
  let h = 0;
  const s = str || "";
  for (let i = 0; i < s.length; i++) {
    h = (h * 31 + s.charCodeAt(i)) >>> 0;
  }
  return h;
}

function pickResonanceByAnswerPath(artistId, artist, history) {
  const list = artist.resonanceLyrics;
  if (!list || !list.length) {
    return { line: "", song: "", neteaseSongId: "" };
  }
  let h = hashString(artistId);
  (history || []).forEach((entry, qi) => {
    h = (h * 31 + qi) >>> 0;
    h = (h ^ hashString(entry.opt && entry.opt.text)) >>> 0;
    h = (h * 31 + Math.round((entry.weight || 1) * 1000)) >>> 0;
  });
  return list[h % list.length];
}

/** 与答题路径绑定的哈希（加盐可与主英雄句区分） */
function pathHashForResonance(artistId, history, salt) {
  let h = hashString(String(artistId) + (salt || ""));
  (history || []).forEach((entry, qi) => {
    h = (h * 31 + qi) >>> 0;
    h = (h ^ hashString(entry.opt && entry.opt.text)) >>> 0;
    h = (h * 31 + Math.round((entry.weight || 1) * 1000)) >>> 0;
  });
  return h >>> 0;
}

/** Fisher–Yates 洗牌（种子固定），取前 take 条，相同路径结果不变 */
function deterministicPermuteTake(arr, seed, take) {
  const n = arr.length;
  if (n <= take) return arr.slice();
  const idx = Array.from({ length: n }, (_, i) => i);
  let h = seed >>> 0;
  for (let i = n - 1; i > 0; i--) {
    h = (h * 1103515245 + 12345) >>> 0;
    const j = h % (i + 1);
    const t = idx[i];
    idx[i] = idx[j];
    idx[j] = t;
  }
  return idx.slice(0, take).map((i) => arr[i]);
}

/** 从池子中展示若干条（不含顶部英雄句），与路径一一对应 */
const RESONANCE_LIST_SHOWN = 3;

function pickResonanceListForPath(artistId, artist, history, hero, maxShown) {
  const list = artist.resonanceLyrics || [];
  const rest = list.filter((r) => !(r.line === hero.line && r.song === hero.song));
  const cap = Math.min(maxShown, rest.length);
  if (cap === 0) return [];
  const seed = pathHashForResonance(artistId, history, ":resonanceList");
  return deterministicPermuteTake(rest, seed, cap);
}

/** 推荐专辑：按与用户六维相似度排序（排除本命），每个歌手只展示一张最契合专辑 */
function buildRecommendedAlbumRows(userNorm, excludeArtistId, maxArtists) {
  const ranked = rankArtistsByProfileSimilarity(userNorm);
  const top = ranked
    .filter(({ id }) => id !== excludeArtistId)
    .slice(0, maxArtists || 3);
  return top.map(({ id }) => {
    const art = ARTISTS[id];
    const meta = pickAlbumMetaForNorm(id, userNorm);
    return {
      artistName: art.name,
      title: meta.title,
      neteaseId: meta.neteaseId,
    };
  });
}

